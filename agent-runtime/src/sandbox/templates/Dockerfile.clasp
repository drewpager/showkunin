# Clasp (Apps Script) Sandbox Executor
# Isolated container for deploying and running Google Apps Script
#
# Security features:
# - Non-root user (node, UID 1000 - built into node:alpine)
# - Minimal base image
# - OAuth credentials injected via tmpfs
# - Read-only root filesystem (tmpfs for /app/code, /tmp, /home/node)

FROM node:20-alpine

# Install dependencies
RUN apk add --no-cache \
    ca-certificates \
    && rm -rf /var/cache/apk/*

# Set up app directory
WORKDIR /app

# Install clasp CLI globally
RUN npm install -g @google/clasp@2.4.2

# Create directories for code, output, and clasp config
# Use existing 'node' user (UID 1000) from base image
RUN mkdir -p /app/code /app/output /home/node/.clasprc \
    && chown -R node:node /app /home/node

# Switch to non-root user
USER node

# Environment for clasp
ENV HOME=/home/node

# Default command (will be overridden by sandbox-manager)
CMD ["clasp", "--version"]
